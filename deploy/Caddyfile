# Caddy reverse proxy for the share-terminal relay.
#
# Caddy obtains and renews a TLS certificate automatically and transparently
# proxies WebSocket upgrades, so hosts/watchers can connect over wss://.
#
# 1. Point an A/AAAA record (e.g. relay.example.com) at this server.
# 2. Replace the domain below with yours.
# 3. caddy run --config ./Caddyfile   (or install Caddy as a service)
#
# Then hosts/watchers use:  wss://relay.example.com

relay.example.com {
	# The relay listens on plain HTTP/WS locally; Caddy adds TLS on top.
	reverse_proxy 127.0.0.1:4455
}
